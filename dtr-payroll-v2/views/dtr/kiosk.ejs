<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daily Time Record | Cor Jesu College</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* Kiosk-specific layout (standalone, no sidebar) */
    /* AFTER */
/* AFTER */
body { background: var(--gray-100); min-height: 100vh; display: flex; flex-direction: column; }
    /* AFTER */
    .header { background: rgba(255,255,255,.07); border-bottom: 1px solid rgba(255,255,255,.1); height: 56px; padding: 0 28px; display: flex; align-items: center; justify-content: space-between; }
    .brand  { display: flex; align-items: center; gap: 10px; }
    .brand img { width: 36px; height: 36px; object-fit: contain; border-radius: 7px; }
    .header { background: var(--white); border-bottom: 1px solid var(--gray-200); height: 56px; padding: 0 28px; display: flex; align-items: center; justify-content: space-between; }
    .brand-name { font-size: 14px; font-weight: 700; color: var(--dark); }
    .brand-sub  { font-size: 11px; color: var(--gray-400); }
    .header-date  { font-size: 12.5px; color: var(--gray-400); }

    .main { flex: 1; display: flex; align-items: center; justify-content: center; padding: 32px 20px; }

.dtr-layout { display: flex; align-items: flex-start; justify-content: center; gap: 20px; }
.fcard-wrap { display: flex; justify-content: center; }
    /* AFTER */
.fcard { background: var(--white); border-radius: 14px; box-shadow: var(--shadow); width: 100%; max-width: 420px; overflow: hidden; flex-shrink: 0; position: relative; z-index: 1; }
    .fcard-accent { height: 4px; background: linear-gradient(90deg, var(--red), #E74C3C); }
    .fcard-body   { padding: 30px; }
    .fcard-title  { font-size: 18px; font-weight: 800; color: var(--dark); margin-bottom: 3px; }
    .fcard-desc   { font-size: 13px; color: var(--gray-400); margin-bottom: 22px; }
    .fcard-foot   { padding: 12px 30px; background: var(--gray-50); border-top: 1px solid var(--gray-200); font-size: 11.5px; color: var(--gray-400); text-align: center; }

    .field       { margin-bottom: 15px; }
    .field label { display: block; font-size: 12.5px; font-weight: 600; color: var(--gray-700); margin-bottom: 6px; }
    .field input {
      width: 100%; padding: 10px 13px;
      border: 1.5px solid var(--gray-200); border-radius: 9px;
      font-family: var(--font); font-size: 14px; color: var(--dark);
      outline: none; background: var(--white);
      transition: border-color .15s, box-shadow .15s;
    }
    .field input:focus { border-color: var(--red); box-shadow: 0 0 0 3px rgba(192,57,43,.1); }
    .field input[readonly] { background: var(--gray-50); font-size: 17px; font-weight: 700; color: var(--gray-700); font-variant-numeric: tabular-nums; cursor: default; }
    .field input[readonly]:focus { box-shadow: none; border-color: var(--gray-200); }

    /* Hint below inputs */
    .field-hint { font-size: 11.5px; color: var(--gray-400); margin-top: 5px; display: flex; align-items: center; gap: 4px; }

    /* pw wrap */
    .pw-wrap { position: relative; }
    .pw-wrap input { padding-right: 40px; }
    .pw-eye { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: var(--gray-400); font-size: 15px; line-height: 1; }
    .pw-eye:hover { color: var(--gray-600); }

    /* Action buttons row */
    .btn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 9px; margin-top: 6px; }
    .btn-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 9px; margin-top: 6px; }
    .kbtn { padding: 10px 8px; border-radius: 9px; font-family: var(--font); font-size: 13px; font-weight: 700; cursor: pointer; border: none; display: flex; align-items: center; justify-content: center; gap: 7px; transition: all .15s; }
    .kbtn:active  { transform: scale(.97); }
    .kbtn:disabled{ opacity: .38; cursor: not-allowed; transform: none !important; }
    .kbtn-in    { background: var(--red);          color: var(--white); }
    .kbtn-in:hover:not(:disabled) { background: var(--red-dark); }
    .kbtn-lunch { background: var(--warning-pale); color: var(--warning); border: 1.5px solid #FCD34D; }
    .kbtn-lunch:hover:not(:disabled) { background: #FDE68A; }
    .kbtn-out   { background: var(--dark);         color: var(--white); }
    .kbtn-out:hover:not(:disabled) { background: var(--gray-700); }
    .kbtn-undo  { background: var(--gray-100);     color: var(--gray-700); border: 1.5px solid var(--gray-200); font-size: 12px; }
    .kbtn-undo:hover:not(:disabled) { background: var(--gray-200); }

    /* Reminder banner */
    .reminder {
      background: var(--info-pale); border: 1px solid #93C5FD; border-radius: 9px;
      padding: 10px 13px; font-size: 12.5px; color: #1E40AF; margin-bottom: 16px;
      display: flex; gap: 9px; align-items: flex-start; line-height: 1.45;
    }
    .reminder i { margin-top: 1px; flex-shrink: 0; }

    /* Employee card */
    
    .emp-card {
  background: var(--white); border-radius: 14px; box-shadow: var(--shadow);
  width: 0; overflow: hidden;
  opacity: 0; pointer-events: none;
  transition: width .3s ease, opacity .3s ease, margin .3s ease;
  flex-shrink: 0; align-self: flex-start;
  margin-left: 0;
}
.emp-card.visible {
  width: 280px;
  opacity: 1; pointer-events: auto;
  margin-left: 20px;
}
  /* AFTER */
.dtr-layout { display: flex; align-items: center; justify-content: center; gap: 20px; width: 100%; }
      .emp-card.visible { opacity: 1; transform: translateY(0); }
      .emp-accent { height: 4px; background: linear-gradient(90deg, var(--red), #E74C3C); }
      .emp-photo-wrap { padding: 24px 24px 14px; display: flex; flex-direction: column; align-items: center; text-align: center; }
      .emp-photo {
      width: 92px; height: 92px; border-radius: 50%;
      background: var(--red); border: 3px solid var(--gray-200);
      display: flex; align-items: center; justify-content: center;
      overflow: hidden; margin-bottom: 12px; position: relative;
    }
    .emp-photo img  { width: 100%; height: 100%; object-fit: cover; display: none; }
    .emp-initials   { font-size: 30px; font-weight: 800; color: var(--white); position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
    .emp-name       { font-size: 15px; font-weight: 800; color: var(--dark); margin-bottom: 3px; }
    .emp-id-text    { font-size: 12px; color: var(--gray-400); margin-bottom: 9px; }
    .emp-times      { border-top: 1px solid var(--gray-200); padding: 12px 18px; display: flex; flex-direction: column; gap: 8px; }
    .etr-row        { display: flex; justify-content: space-between; align-items: center; font-size: 13px; }
    .etr-label      { color: var(--gray-500); font-weight: 500; display: flex; align-items: center; gap: 6px; }
    .etr-dot        { width: 7px; height: 7px; border-radius: 50%; }
    .etr-dot.in     { background: #22C55E; }
    .etr-dot.out    { background: var(--red); }
    .etr-val        { font-weight: 700; color: var(--dark); font-size: 13px; }
    .emp-stamp      { margin: 0 18px 14px; padding: 9px 12px; border-radius: 9px; text-align: center; font-size: 13px; font-weight: 700; display: none; }
    .emp-stamp.in   { background: var(--success-pale); color: var(--success); }
    .emp-stamp.out  { background: var(--danger-pale);  color: var(--danger); }
    .emp-stamp.lunch{ background: var(--warning-pale); color: var(--warning); }

    /* OT/UT summary in emp card */
    .emp-otut       { margin: 0 18px 14px; display: flex; gap: 8px; justify-content: center; }
    .otut-chip      { padding: 4px 11px; border-radius: 20px; font-size: 12px; font-weight: 700; }
    .otut-chip.ot   { background: var(--success-pale); color: var(--success); }
    .otut-chip.ut   { background: var(--danger-pale);  color: var(--danger); }

    @media (max-width: 740px) {
      .dtr-layout { flex-direction: column; align-items: center; }
      .emp-card   { width: 100%; max-width: 420px; }
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="brand">
      <img src="/images/logo.png" alt="CJC Logo">
      <div>
        <div class="brand-name">Cor Jesu College</div>
        <div class="brand-sub">Attendance System</div>
      </div>
    </div>
    <div class="header-right">
      <span class="header-date" id="headerDate"></span>
      <a href="/login" style="font-size:12.5px;color:var(--red);font-weight:600;"><i class="fas fa-lock" style="margin-right:4px"></i>Admin</a>
    </div>
  </header>

  <main class="main">
    <div class="dtr-layout">

      <!-- FORM CARD -->
      <div class="fcard">
        <div class="fcard-accent"></div>
        <div class="fcard-body">
          <div class="fcard-title">Daily Time Record</div>
          <div class="fcard-desc">Enter your ID and password to log attendance.</div>

          <!-- Reminder banner -->
          <div class="reminder">
            <i class="fas fa-info-circle"></i>
            <span>Use <strong>Time In</strong> to start your shift. Use <strong>Lunch Break</strong> when leaving for lunch, then <strong>Time In</strong> again when you return. <strong>Time Out</strong> ends your shift.</span>
          </div>

          <div id="alertBox"></div>

          <div class="field">
            <label for="userId">Employee / Student ID</label>
            <input type="text" id="userId" placeholder="e.g. MNT001 or STD001" autocomplete="off" autofocus maxlength="20" spellcheck="false">
            <div class="field-hint"><i class="fas fa-info-circle"></i> Enter your assigned ID number</div>
          </div>

          <div class="field">
            <label for="password">Password</label>
            <div class="pw-wrap">
              <input type="password" id="password" placeholder="Enter your password" maxlength="50">
              <button type="button" class="pw-eye" id="pwToggle" title="Show/hide password" onclick="togglePw()">
                <i class="fas fa-eye" id="pwIcon"></i>
              </button>
            </div>
            <div class="field-hint"><i class="fas fa-lock"></i> Your password is kept private</div>
          </div>

          <div class="field">
            <label>Current Time</label>
            <input type="text" id="liveTime" readonly value="--:--:--">
          </div>

          <div class="btn-grid-3" id="btnRow">
            <button class="kbtn kbtn-in"    id="btnIn"    onclick="doSubmit('time-in')">
              <i class="fas fa-sign-in-alt"></i> Time In
            </button>
            <button class="kbtn kbtn-lunch" id="btnLunch" onclick="doSubmit('lunch-break')">
              <i class="fas fa-utensils"></i> Lunch
            </button>
            <button class="kbtn kbtn-out"   id="btnOut"   onclick="doSubmit('time-out')">
              <i class="fas fa-sign-out-alt"></i> Time Out
            </button>
          </div>

          <!-- Undo button (shown only after time-out) -->
          <div id="undoRow" style="margin-top:8px;display:none;">
            <button class="kbtn kbtn-undo" style="width:100%;" onclick="doSubmit('undo-timeout')">
              <i class="fas fa-undo"></i> Oops! Undo Last Time-Out (within 5 min)
            </button>
          </div>
        </div>
        <div class="fcard-foot">
          &copy; <%= new Date().getFullYear() %> Cor Jesu College, Inc.
        </div>
      </div>

      <!-- EMPLOYEE CARD -->
      <div class="emp-card" id="empCard">
        <div class="emp-accent"></div>
        <div class="emp-photo-wrap">
          <div class="emp-photo" id="empPhoto">
            <div class="emp-initials" id="empInitials">?</div>
            <img id="empImg" src="" alt="">
          </div>
          <div class="emp-name" id="empName">—</div>
          <div class="emp-id-text" id="empIdText">—</div>
          <span class="badge" id="empBadge">—</span>
        </div>

        <div class="emp-stamp" id="empStamp"></div>
        <div class="emp-otut" id="empOtUt" style="display:none;"></div>

        <div class="emp-times">
          <div class="etr-row">
            <span class="etr-label"><span class="etr-dot in"></span> Time In</span>
            <span class="etr-val" id="empTimeIn">—</span>
          </div>
          <div class="etr-row">
            <span class="etr-label"><span class="etr-dot out"></span> Time Out</span>
            <span class="etr-val" id="empTimeOut">—</span>
          </div>
          <div class="etr-row" id="sessionsRow" style="display:none;">
            <span class="etr-label"><i class="fas fa-utensils" style="color:var(--warning)"></i> Sessions</span>
            <span class="etr-val" id="empSessions">—</span>
          </div>
          <div class="etr-row" id="totalRow" style="display:none;">
            <span class="etr-label"><i class="fas fa-clock" style="color:var(--info)"></i> Total Hours</span>
            <span class="etr-val" id="empTotal" style="color:var(--success)">—</span>
          </div>
        </div>
      </div>

    </div>
  </main>

<script>
  // ── CLOCK ──
  function tick() {
    const now = new Date();
    document.getElementById('liveTime').value =
      now.toLocaleTimeString('en-PH', { hour:'2-digit', minute:'2-digit', second:'2-digit' });
    document.getElementById('headerDate').textContent =
      now.toLocaleDateString('en-PH', { weekday:'short', month:'long', day:'numeric', year:'numeric' });
  }
  tick(); setInterval(tick, 1000);

  // ── ID auto-uppercase ──
  document.getElementById('userId').addEventListener('input', function () {
    const p = this.selectionStart;
    this.value = this.value.toUpperCase();
    this.setSelectionRange(p, p);
  });

  // ── Enter key navigation ──
  document.getElementById('userId').addEventListener('keydown', e => {
    if (e.key === 'Enter') document.getElementById('password').focus();
  });
  document.getElementById('password').addEventListener('keydown', e => {
    if (e.key === 'Enter') doSubmit('time-in');
  });

  // ── Password toggle ──
  function togglePw() {
    const inp  = document.getElementById('password');
    const icon = document.getElementById('pwIcon');
    if (inp.type === 'password') {
      inp.type = 'text';
      icon.className = 'fas fa-eye-slash';
    } else {
      inp.type = 'password';
      icon.className = 'fas fa-eye';
    }
  }

  // ── Submit ──
  let busy = false;
  let lastAction = null;

  async function doSubmit(action) {
    if (busy) return;
    const userId   = document.getElementById('userId').value.trim();
    const password = document.getElementById('password').value;

    if (!userId)   { showAlert('error', 'Please enter your ID.');       document.getElementById('userId').focus();   return; }
    if (!password) { showAlert('error', 'Please enter your password.'); document.getElementById('password').focus(); return; }

    busy = true; setBtns(true); clearAlert();

    try {
      const res  = await fetch('/dtr/kiosk', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, password, action })
      });
      const data = await res.json();

      if (data.success) {
        lastAction = data.action || action;
        showAlert('success', data.message +
          (data.totalHours ? `&nbsp; — &nbsp;Total: <strong>${data.totalHours} hrs</strong>` : ''));
        showEmpCard(data);
        document.getElementById('password').value = '';
        document.getElementById('userId').value   = '';
        document.getElementById('userId').focus();

        // Show undo button only after time-out
        document.getElementById('undoRow').style.display =
          (lastAction === 'time-out') ? 'block' : 'none';
      } else {
        showAlert('error', data.message);
        hideEmpCard();
      }
    } catch (e) {
      showAlert('error', 'Connection error. Please try again.');
      hideEmpCard();
    }

    busy = false; setBtns(false);
  }

  // ── Employee card ──
  function showEmpCard(data) {
    const card   = document.getElementById('empCard');
    const log    = data.todayLog || {};
    const action = data.action;

    // Initials + photo
    const initials = (data.userName || '?').split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
    document.getElementById('empInitials').textContent = initials;
    const img = document.getElementById('empImg');
    img.style.display = 'none';
    img.src = `/images/employees/${data.userId || ''}.jpg`;
    img.onload  = () => { img.style.display='block'; document.getElementById('empInitials').style.display='none'; };
    img.onerror = () => { img.style.display='none';  document.getElementById('empInitials').style.display='flex'; };

    document.getElementById('empName').textContent   = data.userName || '—';
    document.getElementById('empIdText').textContent = data.userId   || '—';

    const badge = document.getElementById('empBadge');
    const isMaint = data.userType === 'maintenance';
    badge.textContent = isMaint ? 'Maintenance' : 'Student';
    badge.className   = 'badge ' + (isMaint ? 'badge-orange' : 'badge-blue');

    // Times
    document.getElementById('empTimeIn').textContent  = log.timeIn  ? fmt(log.timeIn)  : '—';
    document.getElementById('empTimeOut').textContent = log.timeOut ? fmt(log.timeOut) : '—';

    // Sessions count
    const sessCount = (log.sessions || []).length;
    if (sessCount > 0) {
      document.getElementById('sessionsRow').style.display = 'flex';
      document.getElementById('empSessions').textContent   = sessCount + ' afternoon session(s)';
    } else {
      document.getElementById('sessionsRow').style.display = 'none';
    }

    // Total hours
    if (log.totalHours > 0) {
      document.getElementById('totalRow').style.display   = 'flex';
      document.getElementById('empTotal').textContent     = (log.totalHours || 0).toFixed(2) + ' hrs';
    } else {
      document.getElementById('totalRow').style.display   = 'none';
    }

    // OT / UT chips
    const otutDiv = document.getElementById('empOtUt');
    if (data.overtimeHours > 0 || data.undertimeHours > 0) {
      let html = '';
      if (parseFloat(data.overtimeHours) > 0)  html += `<span class="otut-chip ot">+${parseFloat(data.overtimeHours).toFixed(2)} hrs OT</span>`;
      if (parseFloat(data.undertimeHours) > 0) html += `<span class="otut-chip ut">−${parseFloat(data.undertimeHours).toFixed(2)} hrs UT</span>`;
      otutDiv.innerHTML = html;
      otutDiv.style.display = 'flex';
    } else {
      otutDiv.style.display = 'none';
    }

    // Stamp
    const stamp = document.getElementById('empStamp');
    stamp.style.display = 'block';
    if (action === 'time-in' || action === 'resume') {
      stamp.className = 'emp-stamp in';
      stamp.innerHTML = `<i class="fas fa-sign-in-alt"></i> Timed In at ${fmt(new Date())}`;
    } else if (action === 'lunch-break') {
      stamp.className = 'emp-stamp lunch';
      stamp.innerHTML = `<i class="fas fa-utensils"></i> Lunch Break at ${fmt(new Date())}`;
    } else if (action === 'time-out') {
      stamp.className = 'emp-stamp out';
      stamp.innerHTML = `<i class="fas fa-sign-out-alt"></i> Timed Out at ${fmt(new Date())}`;
    } else if (action === 'undo') {
      stamp.className = 'emp-stamp in';
      stamp.innerHTML = `<i class="fas fa-undo"></i> Time-Out undone. Back on clock.`;
    }

    card.classList.add('visible');
  }

  function hideEmpCard() { document.getElementById('empCard').classList.remove('visible'); }

  // ── Helpers ──
  function setBtns(d) {
    ['btnIn','btnLunch','btnOut'].forEach(id => document.getElementById(id).disabled = d);
  }
  function showAlert(type, msg) {
    document.getElementById('alertBox').innerHTML =
      `<div class="alert alert-${type}">
         <i class="fas ${type==='success'?'fa-check-circle':'fa-exclamation-circle'}"></i>
         <span>${msg}</span>
       </div>`;
  }
  function clearAlert() { document.getElementById('alertBox').innerHTML = ''; }
  function fmt(iso) {
    return new Date(iso).toLocaleTimeString('en-PH', { hour:'2-digit', minute:'2-digit', second:'2-digit' });
  }
</script>
</body>
</html>
