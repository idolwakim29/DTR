<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Time Record | CJC DTR</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="dtr-page">

<div class="dtr-container">
  <div class="dtr-header">
    <div class="school-badge">
      <img src="/images/logo.png" alt="" style="width:16px;height:16px;border-radius:3px;">
      Cor Jesu College
    </div>
    <h1>Time Record</h1>
    <p>Log your attendance for today</p>
  </div>

  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
  <% } %>

  <div class="dtr-card">
    <!-- Live clock -->
    <div class="dtr-card-header">
      <div class="dtr-time" id="liveTime">--:--:--</div>
      <div class="dtr-date" id="liveDate">Loading...</div>
    </div>

    <!-- User info -->
    <div class="dtr-user-info">
      <div class="dtr-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
      <div>
        <div class="dtr-user-name"><%= user.name %></div>
        <div class="dtr-user-id">ID: <%= user.userId %></div>
        <span class="badge <%= user.role === 'student' ? 'badge-blue' : 'badge-orange' %>">
          <i class="fas <%= user.role === 'student' ? 'fa-user-graduate' : 'fa-hard-hat' %>"></i>
          <%= user.role === 'student' ? 'Student' : 'Maintenance' %>
        </span>
      </div>
    </div>

    <!-- Reminder -->
    <div style="padding: 0 22px 2px;">
      <div style="background:var(--info-pale);border:1px solid #93C5FD;border-radius:9px;padding:10px 13px;font-size:12.5px;color:#1E40AF;display:flex;gap:8px;align-items:flex-start;line-height:1.45;">
        <i class="fas fa-info-circle" style="margin-top:1px;flex-shrink:0;"></i>
        <span>Lunch break (12:00 PM - 1:00 PM) is automatically excluded from working hours. Use <strong>Time In</strong> to start your shift and <strong>Time Out</strong> to end it.</span>
      </div>
    </div>

    <!-- Today status -->
    <div class="dtr-status-area" style="margin-top:14px;">
      <div class="dtr-log-info">
        <div class="dtr-log-row">
          <span class="dtr-log-label"><i class="fas fa-calendar-day" style="color:var(--red);margin-right:5px"></i>Date</span>
          <span class="dtr-log-value"><%= today %></span>
        </div>
        <div class="dtr-log-row">
          <span class="dtr-log-label"><i class="fas fa-sign-in-alt" style="color:var(--success);margin-right:5px"></i>Time In</span>
          <span class="dtr-log-value">
            <% if (todayLog && todayLog.timeIn) { %>
              <span class="badge badge-green"><%= new Date(todayLog.timeIn).toLocaleTimeString('en-PH',{hour:'2-digit',minute:'2-digit',second:'2-digit'}) %></span>
            <% } else { %>
              <span style="color:var(--gray-400)">Not yet recorded</span>
            <% } %>
          </span>
        </div>
        <div class="dtr-log-row">
          <span class="dtr-log-label"><i class="fas fa-sign-out-alt" style="color:var(--red);margin-right:5px"></i>Time Out</span>
          <span class="dtr-log-value">
            <% if (todayLog && todayLog.status === 'completed') { %>
              <% const lastOut = todayLog.sessions && todayLog.sessions.length > 0 ? todayLog.sessions[todayLog.sessions.length-1].timeOut : todayLog.timeOut; %>
              <span class="badge badge-red"><%= lastOut ? new Date(lastOut).toLocaleTimeString('en-PH',{hour:'2-digit',minute:'2-digit',second:'2-digit'}) : '—' %></span>
            <% } else { %>
              <span style="color:var(--gray-400)">Not yet recorded</span>
            <% } %>
          </span>
        </div>
        <% if (todayLog && todayLog.sessions && todayLog.sessions.length > 0) { %>
        <div class="dtr-log-row">
          <span class="dtr-log-label"><i class="fas fa-utensils" style="color:var(--warning);margin-right:5px"></i>Sessions</span>
          <span class="dtr-log-value"><%= todayLog.sessions.length + 1 %> session(s) today</span>
        </div>
        <% } %>

        <% if (todayLog && todayLog.totalHours > 0) { %>
        <div class="dtr-log-row">
          <span class="dtr-log-label"><i class="fas fa-clock" style="color:var(--info);margin-right:5px"></i>Hours Worked</span>
          <span class="dtr-log-value" style="color:var(--success);">
            <%= todayLog.totalHours.toFixed(2) %> hrs
            <% if (todayLog.overtimeHours > 0) { %>
              <span class="badge badge-green" style="margin-left:4px">+<%= todayLog.overtimeHours.toFixed(2) %> OT</span>
            <% } %>
            <% if (todayLog.undertimeHours > 0) { %>
              <span class="badge badge-red" style="margin-left:4px">-<%= todayLog.undertimeHours.toFixed(2) %> UT</span>
            <% } %>
          </span>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Actions -->
    <div class="dtr-actions">
      <%
        const canTimeIn   = !todayLog || !todayLog.timeIn;
        const canTimeOut  = todayLog && todayLog.isActive && todayLog.status !== 'completed';
      %>
      <form action="/dtr/time-in" method="POST">
        <button type="submit" class="dtr-btn dtr-btn-in <%= canTimeIn ? '' : 'disabled' %>" <%= canTimeIn ? '' : 'disabled' %>>
          <i class="fas fa-sign-in-alt"></i> Time In
        </button>
      </form>
      <form action="/dtr/time-out" method="POST">
        <button type="submit" class="dtr-btn dtr-btn-out <%= canTimeOut ? '' : 'disabled' %>" <%= canTimeOut ? '' : 'disabled' %>>
          <i class="fas fa-sign-out-alt"></i> Time Out
        </button>
      </form>
    </div>

  </div>

  <div class="dtr-logout-link">
    <a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </div>
</div>

<script>
  function updateClock() {
    const now = new Date();
    document.getElementById('liveTime').textContent = now.toLocaleTimeString('en-PH',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
    document.getElementById('liveDate').textContent = now.toLocaleDateString('en-PH',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  }
  updateClock();
  setInterval(updateClock, 1000);
  setTimeout(() => document.querySelectorAll('.alert').forEach(el => el.style.opacity='0'), 5000);
</script>
</body>
</html>
