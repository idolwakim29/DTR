<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | CJC DTR System</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .login-topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      max-width: 420px;
      margin: 20px auto 0;
      padding: 10px 12px;
      border-radius: 10px;
      background: var(--white);
      border: 1px solid var(--gray-200);
      box-shadow: 0 4px 10px rgba(0,0,0,.08);
    }
    .login-topbar .brand { display: flex; align-items: center; gap: 10px; }
    .login-topbar .brand img { width: 28px; height: 28px; border-radius: 5px; }
    .login-topbar .brand-name { font-weight: 700; color: var(--dark); font-size: 14px; }
    .login-topbar .brand-sub { font-size: 11px; color: var(--gray-500); line-height: 1; }
    .login-topbar .date-display { font-size: 12.5px; color: var(--gray-500); display: flex; align-items: center; gap: 6px; }
  </style>
</head>
<body class="login-page">

<div class="login-topbar">
  <div class="brand">
    <img src="/images/logo.png" alt="CJC Logo">
    <div>
      <div class="brand-name">Cor Jesu College</div>
      <div class="brand-sub">Attendance System</div>
    </div>
  </div>
  <div class="date-display"><i class="far fa-calendar"></i> <span id="headerDate"></span></div>
</div>

<!-- AFTER -->
<div class="login-card" style="overflow:hidden;padding-top:0;">
  <div style="height:4px;background:linear-gradient(90deg,#C0392B,#E74C3C);width:calc(100% + 80px);margin-left:-40px;margin-bottom:40px;"></div>
  <div class="login-logo">
    <img src="/images/logo.png" alt="CJC Logo">
    <h1>CJC DTR System</h1>
    <p>Cor Jesu College — Daily Time Record &amp; Payroll</p>
  </div>

  <% if (error && error.length > 0) { %>
    <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
  <% } %>

  <div class="login-divider"></div>

  <form action="/login" method="POST">
    <div class="form-group">
      <label class="form-label" for="userId">
        <i class="fas fa-id-badge" style="color:var(--red);margin-right:5px"></i> User ID
      </label>
      <input type="text" id="userId" name="userId" class="form-control"
        placeholder="e.g. ADMIN001, MNT001, STD001"
        required autofocus autocomplete="off"
        style="text-transform:uppercase"
        oninput="this.value=this.value.toUpperCase()">
      <div class="pw-hint"><i class="fas fa-info-circle"></i> Enter your assigned employee or student ID</div>
    </div>

    <div class="form-group">
      <label class="form-label" for="password">
        <i class="fas fa-lock" style="color:var(--red);margin-right:5px"></i> Password
      </label>
      <div class="input-wrap">
        <input type="password" id="password" name="password" class="form-control"
          placeholder="Enter your password" required>
        <button type="button" class="toggle-pw" onclick="togglePw()" title="Show/hide password">
          <i class="fas fa-eye" id="pwIcon"></i>
        </button>
      </div>
      <div class="pw-hint"><i class="fas fa-shield-alt"></i> Your password is case-sensitive</div>
    </div>

    <button type="submit" class="btn btn-primary login-btn">
      <i class="fas fa-sign-in-alt"></i> Sign In  
    </button>
  </form>

  <div style="text-align:center;margin-top:18px;">
    <a href="/" style="font-size:13px;color:var(--gray-600);"><i class="fas fa-clock" style="margin-right:5px"></i>Go to Kiosk / Time Record</a>
  </div>

  <div class="login-footer">
    &copy; <%= new Date().getFullYear() %> Cor Jesu College, Inc. &mdash; All rights reserved
  </div>
</div>

<script>
  function togglePw() {
    const inp  = document.getElementById('password');
    const icon = document.getElementById('pwIcon');
    if (inp.type === 'password') {
      inp.type = 'text';
      icon.className = 'fas fa-eye-slash';
    } else {
      inp.type = 'password';
      icon.className = 'fas fa-eye';
    }
  }
  // Auto dismiss error
  setTimeout(() => document.querySelectorAll('.alert').forEach(el => el.style.opacity='0'), 5000);

  function updateHeaderDate() {
    const now = new Date();
    document.getElementById('headerDate').textContent = now.toLocaleDateString('en-PH', { weekday:'long', year:'numeric', month:'long', day:'numeric'});
  }
  updateHeaderDate();
  setInterval(updateHeaderDate, 60000);
</script>
</body>
</html>
