<%- include('../partials/admin-header') %>

<div class="card">
  <div class="card-header">
    <h3 class="card-title"><i class="fas fa-money-bill-wave" style="color:var(--red);margin-right:8px"></i>Payroll Records</h3>
    <a href="/admin/payroll/generate" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Generate Payroll</a>
  </div>
  <div class="card-body">
    <form method="GET" class="filter-bar">
      <select name="userType" class="form-select" style="width:180px">
        <option value="">All Types</option>
        <option value="maintenance" <%= userType === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
        <option value="student" <%= userType === 'student' ? 'selected' : '' %>>Student</option>
      </select>
      <select name="status" class="form-select" style="width:180px">
        <option value="">All Status</option>
        <option value="unpaid" <%= status === 'unpaid' ? 'selected' : '' %>>Unpaid</option>
        <option value="paid" <%= status === 'paid' ? 'selected' : '' %>>Paid</option>
      </select>
      <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Filter</button>
      <a href="/admin/payroll" class="btn btn-secondary"><i class="fas fa-times"></i> Clear</a>
    </form>

    <div class="table-wrap">
      <% if (payrolls.length === 0) { %>
        <div class="empty-state"><i class="fas fa-file-invoice-dollar"></i><p>No payroll records found</p></div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Period</th>
            <th>Rate/hr</th>
            <th>Hours</th>
            <th>OT / UT</th>
            <th>Total Salary</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% payrolls.forEach(p => { %>
          <tr>
            <td>
              <strong><%= p.userName %></strong><br>
              <small style="color:var(--gray-600)"><%= p.userId %></small>
            </td>
            <td>
              <span class="badge <%= p.userType === 'student' ? 'badge-blue' : 'badge-orange' %>">
                <%= p.userType.charAt(0).toUpperCase() + p.userType.slice(1) %>
              </span>
            </td>
            <td>
              <span class="badge badge-gray"><%= p.periodType %></span><br>
              <small style="color:var(--gray-600);font-size:11px">
                <%= new Date(p.periodStart).toLocaleDateString('en-PH') %> – <%= new Date(p.periodEnd).toLocaleDateString('en-PH') %>
              </small>
            </td>
            <td>₱<%= p.hourlyRate.toFixed(2) %></td>
            <td><strong><%= p.totalHoursWorked.toFixed(2) %> hrs</strong></td>
            <td>
              <% if (p.totalOvertimeHours > 0) { %>
                <span class="badge badge-green">+<%= p.totalOvertimeHours.toFixed(2) %> OT</span>
              <% } else if (p.totalUndertimeHours > 0) { %>
                <span class="badge badge-red">−<%= p.totalUndertimeHours.toFixed(2) %> UT</span>
              <% } else { %>
                <span style="color:var(--gray-400)">—</span>
              <% } %>
            </td>
            <td class="payroll-amount">₱<%= p.totalSalary.toFixed(2) %></td>
            <td>
              <span class="badge <%= p.paymentStatus === 'paid' ? 'badge-green' : 'badge-red' %>">
                <i class="fas <%= p.paymentStatus === 'paid' ? 'fa-check' : 'fa-clock' %>"></i>
                <%= p.paymentStatus === 'paid' ? 'Paid' : 'Unpaid' %>
              </span>
              <% if (p.paidAt) { %>
                <br><small style="color:var(--gray-600);font-size:11px"><%= new Date(p.paidAt).toLocaleDateString('en-PH') %></small>
              <% } %>
            </td>
            <td>
              <div style="display:flex;gap:6px;flex-wrap:wrap">
                <% if (p.paymentStatus !== 'paid') { %>
                <form action="/admin/payroll/pay/<%= p._id %>" method="POST" onsubmit="return confirm('Mark this payroll as Paid?')">
                  <button class="btn btn-sm btn-success" title="Mark Paid"><i class="fas fa-check"></i></button>
                </form>
                <% } %>
                <form action="/admin/payroll/delete/<%= p._id %>" method="POST" onsubmit="return confirm('Delete this record?')">
                  <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/admin-footer') %>
