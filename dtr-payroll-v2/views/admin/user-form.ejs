<%- include('../partials/admin-header') %>

<div class="card" style="max-width:580px;">
  <div class="card-header">
    <h3 class="card-title">
      <i class="fas <%= editUser ? 'fa-edit' : 'fa-user-plus' %>" style="color:var(--red);margin-right:8px"></i>
      <%= editUser ? 'Edit User' : 'Add New User' %>
    </h3>
    <a href="/admin/users" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
  <div class="card-body">
    <% if (error && error.length > 0) { %>
      <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>

    <form action="<%= editUser ? '/admin/users/edit/' + editUser._id : '/admin/users/new' %>" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">User ID *</label>
          <input type="text" name="userId" class="form-control"
            value="<%= editUser ? editUser.userId : '' %>"
            <%= editUser ? 'readonly style="background:var(--gray-50)"' : 'required placeholder="e.g. MNT001"' %>
            style="text-transform:uppercase" oninput="this.value=this.value.toUpperCase()">
        </div>
        <div class="form-group">
          <label class="form-label">Role *</label>
          <select name="role" class="form-select" required>
            <option value="">Select Role</option>
            <option value="maintenance" <%= editUser && editUser.role === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
            <option value="student"     <%= editUser && editUser.role === 'student'     ? 'selected' : '' %>>Student</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Full Name *</label>
        <input type="text" name="name" class="form-control" required placeholder="Full name"
          value="<%= editUser ? editUser.name : '' %>">
      </div>

      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" placeholder="email@cjc.edu.ph"
          value="<%= editUser ? editUser.email || '' : '' %>">
      </div>

      <div class="form-group">
        <label class="form-label">Department</label>
        <input type="text" name="department" class="form-control" placeholder="e.g. Facilities, BSIT"
          value="<%= editUser ? editUser.department || '' : '' %>">
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Hourly Rate (₱)</label>
          <input type="number" name="hourlyRate" class="form-control" step="0.01" min="0" placeholder="0.00"
            value="<%= editUser ? editUser.hourlyRate || 0 : '' %>">
        </div>
        <div class="form-group">
          <label class="form-label">Required Hours / Day</label>
          <input type="number" name="requiredHours" class="form-control" step="0.5" min="1" max="24" placeholder="8"
            value="<%= editUser ? editUser.requiredHours || 8 : 8 %>">
          <div class="pw-hint"><i class="fas fa-info-circle"></i> For OT/UT calculation</div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label"><%= editUser ? 'New Password (leave blank to keep)' : 'Password *' %></label>
        <div class="input-wrap">
          <input type="password" name="password" class="form-control" id="pwField"
            <%= editUser ? '' : 'required' %> placeholder="Enter password"
            minlength="6">
          <button type="button" class="toggle-pw" onclick="togglePw()" title="Show/hide">
            <i class="fas fa-eye" id="pwIcon"></i>
          </button>
        </div>
        <div class="pw-hint"><i class="fas fa-info-circle"></i> Minimum 6 characters</div>
      </div>

      <% if (editUser) { %>
      <div class="form-group">
        <label class="form-label">Status</label>
        <div style="display:flex;align-items:center;gap:10px;margin-top:4px;">
          <input type="checkbox" name="isActive" id="isActive" <%= editUser.isActive ? 'checked' : '' %>
            style="width:16px;height:16px;accent-color:var(--red);">
          <label for="isActive" style="font-size:13.5px;color:var(--gray-700);cursor:pointer;margin:0;">Active account</label>
        </div>
      </div>
      <% } %>

      <div style="display:flex;gap:10px;margin-top:8px;">
        <button type="submit" class="btn btn-primary">
          <i class="fas <%= editUser ? 'fa-save' : 'fa-user-plus' %>"></i>
          <%= editUser ? 'Save Changes' : 'Create User' %>
        </button>
        <a href="/admin/users" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>

<script>
function togglePw() {
  const inp  = document.getElementById('pwField');
  const icon = document.getElementById('pwIcon');
  if (inp.type === 'password') { inp.type = 'text'; icon.className = 'fas fa-eye-slash'; }
  else { inp.type = 'password'; icon.className = 'fas fa-eye'; }
}
</script>

<%- include('../partials/admin-footer') %>
