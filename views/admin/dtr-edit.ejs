<%- include('../partials/admin-header') %>

<div class="card" style="max-width:560px;">
  <div class="card-header">
    <h3 class="card-title"><i class="fas fa-edit" style="color:var(--red);margin-right:8px"></i>Edit DTR Log</h3>
    <a href="<%= log.userType === 'maintenance' ? '/admin/dtr/maintenance' : '/admin/dtr/students' %>" class="btn btn-secondary btn-sm">
      <i class="fas fa-arrow-left"></i> Back
    </a>
  </div>
  <div class="card-body">

    <!-- Read-only summary -->
    <div style="background:var(--gray-50);border:1px solid var(--gray-200);border-radius:10px;padding:14px 16px;margin-bottom:22px;font-size:13.5px;">
      <div style="display:flex;gap:24px;flex-wrap:wrap;">
        <div><span style="color:var(--gray-500)">Employee</span><br><strong><%= log.userName %></strong></div>
        <div><span style="color:var(--gray-500)">ID</span><br><strong><%= log.userId %></strong></div>
        <div><span style="color:var(--gray-500)">Date</span><br><strong><%= log.date %></strong></div>
        <div><span style="color:var(--gray-500)">Type</span><br>
          <span class="badge <%= log.userType === 'student' ? 'badge-blue' : 'badge-orange' %>">
            <%= log.userType.charAt(0).toUpperCase() + log.userType.slice(1) %>
          </span>
        </div>
      </div>
    </div>

    <form action="/admin/dtr/edit/<%= log._id %>" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label"><i class="fas fa-sign-in-alt" style="color:var(--success);margin-right:5px"></i>Time In</label>
          <input type="datetime-local" name="timeIn" class="form-control"
            value="<%= log.timeIn ? new Date(log.timeIn).toISOString().slice(0,16) : '' %>">
        </div>
        <div class="form-group">
          <label class="form-label"><i class="fas fa-sign-out-alt" style="color:var(--red);margin-right:5px"></i>Time Out</label>
          <input type="datetime-local" name="timeOut" class="form-control"
            value="<%= log.timeOut ? new Date(log.timeOut).toISOString().slice(0,16) : '' %>">
        </div>
      </div>

      <div class="form-group">
        <label class="form-label"><i class="fas fa-clock" style="color:var(--info);margin-right:5px"></i>Required Hours / Day</label>
        <input type="number" name="requiredHours" class="form-control" step="0.5" min="1" max="24"
          value="<%= log.requiredHours || 8 %>" style="max-width:180px;">
        <div class="pw-hint"><i class="fas fa-info-circle"></i> Used to calculate overtime and undertime</div>
      </div>

      <div class="form-group" style="margin-bottom:15px; display:flex; align-items:center; gap:8px;">
        <input type="checkbox" name="late_afternoon" id="late_afternoon" <%= log.late_afternoon ? 'checked' : '' %>>
        <label for="late_afternoon" style="margin-bottom:0; font-weight:600;"><i class="fas fa-exclamation-triangle" style="color:var(--orange);margin-right:5px"></i>Flag as Late Afternoon</label>
      </div>

      <div class="form-group">
        <label class="form-label"><i class="fas fa-sticky-note" style="color:var(--gray-500);margin-right:5px"></i>Notes</label>
        <input type="text" name="notes" class="form-control" placeholder="Optional notes..."
          value="<%= log.notes || '' %>">
      </div>

      <!-- Current computed values (read-only display) -->
      <% if (log.totalHours > 0) { %>
      <div style="background:var(--gray-50);border:1px solid var(--gray-200);border-radius:10px;padding:14px 16px;margin-bottom:20px;">
        <div style="font-size:12px;font-weight:700;color:var(--gray-500);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;">Current Computed Values</div>
        <div style="display:flex;gap:20px;flex-wrap:wrap;font-size:13.5px;">
          <div><span style="color:var(--gray-500)">Total Hours</span><br><strong><%= log.totalHours.toFixed(2) %> hrs</strong></div>
          <div><span style="color:var(--gray-500)">Overtime</span><br>
            <strong style="color:var(--success)"><%= log.overtimeHours > 0 ? '+' + log.overtimeHours.toFixed(2) + ' hrs' : '—' %></strong>
          </div>
          <div><span style="color:var(--gray-500)">Undertime</span><br>
            <strong style="color:var(--danger)"><%= log.undertimeHours > 0 ? '−' + log.undertimeHours.toFixed(2) + ' hrs' : '—' %></strong>
          </div>
          <div><span style="color:var(--gray-500)">Status</span><br>
            <span class="badge <%= log.status === 'completed' ? 'badge-green' : log.status === 'on-break' ? 'badge-orange' : 'badge-blue' %>">
              <%= log.status %>
            </span>
          </div>
        </div>
      </div>
      <% } %>

      <div style="display:flex;gap:10px;">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Changes</button>
        <a href="<%= log.userType === 'maintenance' ? '/admin/dtr/maintenance' : '/admin/dtr/students' %>" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/admin-footer') %>
