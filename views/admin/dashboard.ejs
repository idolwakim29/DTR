<%- include('../partials/admin-header') %>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon orange"><i class="fas fa-hard-hat"></i></div>
    <div>
      <div class="stat-value"><%= stats.totalMaintenance || 0 %></div>
      <div class="stat-label">Maintenance Staff</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon blue"><i class="fas fa-user-graduate"></i></div>
    <div>
      <div class="stat-value"><%= stats.totalStudents || 0 %></div>
      <div class="stat-label">Students</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon red"><i class="fas fa-clipboard-list"></i></div>
    <div>
      <div class="stat-value"><%= stats.totalLogs || 0 %></div>
      <div class="stat-label">Total DTR Logs</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green"><i class="fas fa-money-bill-wave"></i></div>
    <div>
      <div class="stat-value"><%= stats.totalPayrolls || 0 %></div>
      <div class="stat-label">Payrolls Generated</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon gray" style="background:#dee2e6;color:#495057"><i class="fas fa-user-times"></i></div>
    <div>
      <div class="stat-value"><%= extraStats.totalAbsentToday %></div>
      <div class="stat-label">Absent Today</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon orange"><i class="fas fa-hand-holding-usd"></i></div>
    <div>
      <div class="stat-value"><%= extraStats.advances.count %></div>
      <div class="stat-label">Pending Cash Adv. (₱<%= extraStats.advances.totalAmount.toFixed(2) %>)</div>
    </div>
  </div>
</div>

<div class="grid-2">
  <!-- Today's Attendance -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title"><i class="fas fa-calendar-check" style="color:var(--red);margin-right:8px"></i>Today's Attendance</h3>
      <span class="badge badge-gray"><%= today %></span>
    </div>
    <div class="table-wrap">
      <% if (todayLogs.length === 0) { %>
        <div class="empty-state">
          <i class="fas fa-clipboard"></i>
          <p>No attendance records today</p>
        </div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Time In</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% todayLogs.forEach(log => { %>
          <tr>
            <td><strong><%= log.userName %></strong><br><small style="color:var(--gray-600)"><%= log.userId %></small></td>
            <td>
              <span class="badge <%= log.userType === 'student' ? 'badge-blue' : 'badge-orange' %>">
                <%= log.userType === 'student' ? 'Student' : 'Maintenance' %>
              </span>
            </td>
            <td><%= log.timeIn ? new Date(log.timeIn).toLocaleTimeString('en-PH', {hour:'2-digit',minute:'2-digit'}) : '—' %></td>
            <td>
              <span class="badge <%= log.status === 'completed' ? 'badge-green' : 'badge-orange' %>">
                <%= log.status === 'completed' ? 'Completed' : 'In Progress' %>
              </span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>

  <!-- Recent Payrolls -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title"><i class="fas fa-receipt" style="color:var(--red);margin-right:8px"></i>Recent Payrolls</h3>
      <a href="/admin/payroll" class="btn btn-outline btn-sm">View All</a>
    </div>
    <div class="table-wrap">
      <% if (recentPayrolls.length === 0) { %>
        <div class="empty-state">
          <i class="fas fa-file-invoice-dollar"></i>
          <p>No payrolls generated yet</p>
        </div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Amount</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% recentPayrolls.forEach(p => { %>
          <tr>
            <td><strong><%= p.userName %></strong><br><small style="color:var(--gray-600)"><%= p.periodType %></small></td>
            <td class="payroll-amount">₱<%= p.totalSalary.toFixed(2) %></td>
            <td>
              <span class="badge <%= p.paymentStatus === 'paid' ? 'badge-green' : 'badge-red' %>">
                <%= p.paymentStatus === 'paid' ? 'Paid' : 'Unpaid' %>
              </span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/admin-footer') %>
